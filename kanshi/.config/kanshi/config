profile default {
  output "eDP-1" enable
}

profile xreal-air-1 {
  output "eDP-1" disable
  output "Nreal Air 0x66666600" res --custom 1600x900 scale 1.15
  exec notify-send "new kanshi profile applied"
}

profile xreal-air-2 {
  output "eDP-1" disable
  output "Nreal Air 2 0x88888800" res --custom 1600x900 scale 1.15
  exec notify-send "new kanshi profile applied"
}

# keep this at bottom: earlier profiles match before later ones
profile docked {
  output "eDP-1" disable
  output * enable mode preferred position 0,0
}

# `pkill -HUP kanshi` to reload !
